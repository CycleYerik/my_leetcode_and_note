{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "C/C++: g++.exe 编译当前文件",
      "type": "shell",
      "command": "D:\\mingw64\\bin\\g++.exe",
      "args": [
        "-std=c++17",
        "-fdiagnostics-color=always",
        "-g",
        "${file}",
        "-o",
        "${fileDirname}\\${fileBasenameNoExtension}.exe"
      ],
      "options": {
        "cwd": "${fileDirname}"
      },
      "problemMatcher": ["$gcc"],
      "group": "build",
      "detail": "仅编译，不运行"
    },
    {
      "label": "C/C++: 编译并运行（推荐，无需调试器）",
      "type": "shell",
      "dependsOn": ["C/C++: g++.exe 编译当前文件"],
      "dependsOrder": "sequence",
      "command": "${fileDirname}\\${fileBasenameNoExtension}.exe",
      "options": {
        "cwd": "${fileDirname}"
      },
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": true,
        "clear": true
      },
      "detail": "等同终端 g++ && .\\xxx.exe；Ctrl+Shift+B 触发"
    }
  ]
}
