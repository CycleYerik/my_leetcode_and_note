{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "① 编译并运行（F5 推荐，无需 cppdbg）",
      "type": "node-terminal",
      "request": "launch",
      "command": "${input:compileAndRunCurrentCpp}"
    },
    {
      "name": "② LLDB 断点调试（需 CodeLLDB 扩展）",
      "type": "lldb",
      "request": "launch",
      "program": "${fileDirname}\\${fileBasenameNoExtension}.exe",
      "cwd": "${fileDirname}",
      "preLaunchTask": "C/C++: g++.exe 编译当前文件"
    },
    {
      "name": "③ gdb 调试（需 Microsoft C/C++ 扩展启用 cppdbg）",
      "type": "cppdbg",
      "request": "launch",
      "program": "${fileDirname}\\${fileBasenameNoExtension}.exe",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${fileDirname}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "D:\\mingw64\\bin\\gdb.exe",
      "setupCommands": [
        {
          "description": "为 gdb 启用整齐打印",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],
      "preLaunchTask": "C/C++: g++.exe 编译当前文件"
    }
  ],
  "inputs": [
    {
      "id": "compileAndRunCurrentCpp",
      "type": "command",
      "command": "workbench.action.tasks.runTask",
      "args": "C/C++: 编译并运行（推荐，无需调试器）"
    }
  ]
}
